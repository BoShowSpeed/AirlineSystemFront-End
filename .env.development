# API base URL the frontend calls.
# While the backend isn't ready, keep this as "/api" and let MSW mock it.
# When your team's Laravel API is running, change to e.g. http://localhost:8000/api
VITE_API_URL=/api

# Turn the in-browser mock API (MSW) on/off.
# true  = use mock data (no backend needed)
# false = hit the real VITE_API_URL
VITE_ENABLE_MOCKS=true
