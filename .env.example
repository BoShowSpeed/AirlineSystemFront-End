# Copy to .env.local (or .env.development) and adjust.

# Base URL of the Airline API.
#   /api                        -> relative, used with the MSW mock (default dev)
#   http://localhost:8000/api   -> your team's local Laravel API
VITE_API_URL=/api

# Enable the in-browser mock API (MSW). Set to false to use the real backend.
VITE_ENABLE_MOCKS=true
